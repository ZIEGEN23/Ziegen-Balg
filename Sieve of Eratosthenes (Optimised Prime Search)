#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <string.h>

/**
 * Finds all prime numbers up to 'limit' using the Sieve of Eratosthenes algorithm.
 */
void sieveOfEratosthenes(int limit) {
    // Dynamically allocate a boolean array to store prime status
    bool *isPrime = malloc((limit + 1) * sizeof(bool));
    if (isPrime == NULL) {
        printf("Memory allocation failed!\n");
        return;
    }

    // Initialize all entries as true
    memset(isPrime, true, (limit + 1) * sizeof(bool));
    isPrime[0] = isPrime[1] = false; // 0 and 1 are not prime

    for (int p = 2; p * p <= limit; p++) {
        if (isPrime[p]) {
            // Mark multiples of p as not prime
            for (int i = p * p; i <= limit; i += p)
                isPrime[i] = false;
        }
    }

    // Output the results
    printf("Prime numbers up to %d:\n", limit);
    for (int p = 2; p <= limit; p++) {
        if (isPrime[p]) printf("%d ", p);
    }
    printf("\n");

    free(isPrime); // Always free dynamic memory
}

int main() {
    int limit;
    printf("Enter the upper limit to find primes: ");
    if (scanf("%d", &limit) == 1 && limit >= 2) {
        sieveOfEratosthenes(limit);
    } else {
        printf("Please enter a valid integer >= 2.\n");
    }
    return 0;
}
