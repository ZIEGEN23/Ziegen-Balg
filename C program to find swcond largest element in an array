#include <stdio.h>
#include <limits.h>
int main() {
    int n, max1=INT_MIN, max2=INT_MIN;
    scanf("%d", &n);
    int a[n];
    for(int i=0; i<n; i++) {
        scanf("%d", &a[i]);
        if(a[i] > max1) { max2 = max1; max1 = a[i]; }
        else if(a[i] > max2 && a[i] < max1) max2 = a[i];
    }
    printf("Second Largest: %d", max2);
    return 0;
}
