#include <stdio.h>
int main() {
    char line[100];
    int v = 0, c = 0;
    printf("Enter a string: ");
    scanf("%s", line);
    for (int i = 0; line[i] != '\0'; ++i) {
        if (line[i] == 'a' || line[i] == 'e' || line[i] == 'i' || line[i] == 'o' || line[i] == 'u') v++;
        else if ((line[i] >= 'a' && line[i] <= 'z')) c++;
    }
    printf("Vowels: %d, Consonants: %d", v, c);
    return 0;
}
