#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void checkIPClass(char *ip) {
    char *token = strtok(ip, ".");
    int firstOctet = atoi(token);

    if (firstOctet >= 0 && firstOctet <= 127) printf("Class A\n");
    else if (firstOctet >= 128 && firstOctet <= 191) printf("Class B\n");
    else if (firstOctet >= 192 && firstOctet <= 223) printf("Class C\n");
    else printf("Other Class\n");
}

int main() {
    char ip[20] = "192.168.1.1";
    checkIPClass(ip);
    return 0;
}
