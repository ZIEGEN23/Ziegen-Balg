#include <stdio.h>
int stack[5], top = -1;
void push(int val) {
    if (top == 4) printf("Stack Overflow\n");
    else stack[++top] = val;
}
int main() {
    int choice, val;
    while(1) {
        printf("\n1.Push 2.Pop 3.Exit: ");
        scanf("%d", &choice);
        if(choice == 1) { printf("Value: "); scanf("%d", &val); push(val); }
        else if(choice == 2) { 
            if(top == -1) printf("Underflow\n");
            else printf("Popped: %d\n", stack[top--]);
        } else break;
    }
    return 0;
}
